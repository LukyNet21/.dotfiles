#compdef project_manager.sh project_manager

local projects
local project_root=~/projects

if [[ -d $project_root ]]; then
  projects=( ${project_root}/*(/N:t) )
else
  projects=()
fi

_arguments \
  '1:project_name:->proj' && return 0

if [[ $state == proj ]]; then
  _values 'project_name' ${projects[@]}
fi
